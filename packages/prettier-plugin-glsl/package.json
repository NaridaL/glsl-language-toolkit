{
  "name": "prettier-plugin-glsl",
  "repository": {
    "type": "git",
    "url": "https://github.com/NaridaL/glsl-language-toolkit.git",
    "directory": "packages/prettier-plugin-glsl"
  },
  "files": [
    "src",
    "lib"
  ],
  "version": "0.2.5",
  "description": "Prettier (https://prettier.io) plugin for GLSL (OpenGL Shading Language).",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    "default": "./lib/prettier-plugin.cjs.js",
    "types": "./lib/prettier-plugin.d.ts"
  },
  "type": "commonjs",
  "types": "lib/prettier-plugin.d.ts",
  "scripts": {
    "prepublishOnly": "npm run clean && npm run build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test-watch": "jest --watch",
    "watch": "ts-node-dev -T --respawn src/gendiagrams.ts",
    "lint": "eslint src --ext ts",
    "lint-fix": "eslint src --ext ts --fix",
    "build": "rollup --config",
    "clean": "rimraf lib"
  },
  "keywords": [
    "formatter",
    "glsl",
    "prettier",
    "plugin"
  ],
  "author": "Adrian Leonhard",
  "license": "MIT",
  "dependencies": {
    "@netflix/nerror": "^1.1.3",
    "chevrotain": "^12.0.0"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/dedent": "^0.7.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/node-fetch": "^2.6.3",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "babel-jest": "^30.3.0",
    "eslint": "9.26.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-cflint": "^1.0.0",
    "eslint-plugin-import": "^2.27.5",
    "filesize": "^10.0.7",
    "jest": "^30.0.0",
    "node-fetch": "^3.3.1",
    "rollup": "^4.60.1",
    "ts-node-dev": "^2.0.0",
    "tslib": "^2.8.1"
  }
}
